# Database - Development (local MySQL)
DATABASE_URL="mysql://root:@localhost:3306/bazar_abem"

# Para producción en Railway MySQL, usa esta URL:
# DATABASE_URL="mysql://root:sytPXxnDsMtHkfRdiMHmQbnBwDQuJjsi@proxy.railway.internal:3306/railway"

# JWT
JWT_SECRET=tu_secret_key_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=tu_refresh_secret_aqui_cambiar_en_produccion
JWT_REFRESH_EXPIRES_IN=30d

# Server
PORT=3000
NODE_ENV=development

# Frontend URL para CORS
# Development: http://localhost:5173
# Production: https://tu-proyecto.up.railway.app
FRONTEND_URL=http://localhost:5173

# Email provider: resend | smtp
EMAIL_PROVIDER=resend

# Resend (modo recomendado si tienes dominio verificado)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Bazar Abem <facturacion@tu-dominio.com>

# SMTP (alternativa gratuita recomendada: Brevo)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USERNAME=tu_usuario_smtp
# SMTP_PASSWORD=tu_password_smtp
# SMTP_FROM_EMAIL=notificaciones@tu-dominio.com
# SMTP_FROM_NAME=Bazar Abem

# Timezone
TZ=America/Lima
